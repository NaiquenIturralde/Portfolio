@namespace PortfolioNaiquen.Shared.Components

<div class="image-carousel">
    <div class="carousel-container">
        <div class="carousel-track" style="transform: translateX(-@(currentIndex * 100)%)">
            @foreach (var image in Images)
            {
                <div class="carousel-slide">
                    <img src="@image" alt="Imagen del proyecto" loading="lazy" />
                </div>
            }
        </div>
        
        @if (Images.Count > 1)
        {
            <button class="carousel-arrow carousel-arrow-left" @onclick="PreviousSlide" aria-label="Imagen anterior">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 18l-6-6 6-6"/>
                </svg>
            </button>
            
            <button class="carousel-arrow carousel-arrow-right" @onclick="NextSlide" aria-label="Siguiente imagen">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 18l6-6-6-6"/>
                </svg>
            </button>
            
            <div class="carousel-indicators">
                @for (int i = 0; i < Images.Count; i++)
                {
                    int index = i;
                    <button 
                        class="carousel-indicator @(currentIndex == index ? "active" : "")" 
                        @onclick="() => GoToSlide(index)"
                        aria-label="Ir a imagen @(index + 1)">
                    </button>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public List<string> Images { get; set; } = new();
    
    private int currentIndex = 0;
    
    private void NextSlide()
    {
        currentIndex = (currentIndex + 1) % Images.Count;
    }
    
    private void PreviousSlide()
    {
        currentIndex = (currentIndex - 1 + Images.Count) % Images.Count;
    }
    
    private void GoToSlide(int index)
    {
        currentIndex = index;
    }
}
