@namespace PortfolioNaiquen.Shared.Components


@code {
    [Parameter]
    public string ImageSrc { get; set; } = "";

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public EventCallback OnOpen { get; set; }

    private async Task OpenOverlay()
    {
        await OnOpen.InvokeAsync();
    }
}