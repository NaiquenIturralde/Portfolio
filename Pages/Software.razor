@page "/software"
@using PortfolioNaiquen.Shared.Components
@inject PortfolioNaiquen.Services.LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("navSoftware") - Naiquen Iturralde</PageTitle>

<div class="portfolio-page">
    <section class="page-hero fade-in">
        <div class="hero-content">
            <h1 class="page-title">
                <span class="gradient-text">@Lang.T("softwarePageTitle")</span>
            </h1>
            <p class="page-subtitle">@Lang.T("softwarePageSubtitle")</p>
            <p class="page-intro">@Lang.T("softwarePageIntro")</p>
        </div>
    </section>

    <section class="featured-section fade-in">
        <div class="software-card glass">
            <div class="software-card__media software-card__media--featured">
                <img src="img/love2read.png" alt="Love2Read Logo" />
            </div>
            <div class="software-card__content">
                <p class="project-meta-label">@Lang.T("love2readMetaLabel")</p>
                <h2 class="project-featured-title">Love2Read</h2>

                <div class="project-section">
                    <p class="project-section-label">@Lang.T("love2readProblemLabel")</p>
                    <p class="project-problem-text">@Lang.T("love2readProblemText")</p>
                </div>

                <div class="project-section">
                    <p class="project-section-label">@Lang.T("love2readFeaturesLabel")</p>
                    <ul class="project-features-list">
                        <li>@Lang.T("love2readFeature1")</li>
                        <li>@Lang.T("love2readFeature2")</li>
                        <li>@Lang.T("love2readFeature3")</li>
                        <li>@Lang.T("love2readFeature4")</li>
                        <li>@Lang.T("love2readFeature5")</li>
                    </ul>
                </div>

                <div class="project-section">
                    <p class="project-section-label">@Lang.T("love2readArchLabel")</p>
                    <div class="project-arch-pills">
                        <span class="project-arch-pill">ASP.NET Core API</span>
                        <span class="project-arch-pill">SQL Server</span>
                        <span class="project-arch-pill">SPA (HTML, CSS, JS)</span>
                    </div>
                </div>

                <div class="project-featured-tags">
                    @foreach (var tag in new List<string> { ".NET", "SQL Server", "MVC", "Bootstrap", "UX/UI" })
                    {
                        <span class="tag">@tag</span>
                    }
                </div>
                <div class="project-featured-buttons">
                    <a href="https://github.com/NaiquenIturralde" class="project-button demo-button" target="_blank"
                       rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24">
                            <polygon points="5 3 19 12 5 21 5 3" fill="currentColor" stroke="none" />
                        </svg>
                        @Lang.T("verDemo")
                    </a>
                    <a href="https://github.com/NaiquenIturralde" class="project-button code-button" target="_blank"
                       rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24">
                            <path
                            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                        </svg>
                        @Lang.T("verCodigo")
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="projects-section fade-in">
        <div class="software-cards-list">

            <div class="software-card glass">
                <div class="software-card__media">
                    <img src="img/OjoCryptoView.png" alt="CryptoView" loading="lazy" />
                </div>
                <div class="software-card__content">
                    <p class="project-meta-label">@Lang.T("cryptoviewMetaLabel")</p>
                    <h2 class="project-featured-title">CryptoView</h2>

                    <div class="project-section">
                        <p class="project-section-label">@Lang.T("cryptoviewProblemLabel")</p>
                        <p class="project-problem-text">@Lang.T("cryptoviewProblemText")</p>
                    </div>

                    <div class="project-section">
                        <p class="project-section-label">@Lang.T("cryptoviewFeaturesLabel")</p>
                        <ul class="project-features-list">
                            <li>@Lang.T("cryptoviewFeature1")</li>
                            <li>@Lang.T("cryptoviewFeature2")</li>
                            <li>@Lang.T("cryptoviewFeature3")</li>
                            <li>@Lang.T("cryptoviewFeature4")</li>
                            <li>@Lang.T("cryptoviewFeature5")</li>
                            <li>@Lang.T("cryptoviewFeature6")</li>
                        </ul>
                    </div>

                    <div class="project-section">
                        <p class="project-section-label">@Lang.T("cryptoviewArchLabel")</p>
                        <div class="project-arch-pills">
                            <span class="project-arch-pill">Blazor Server</span>
                            <span class="project-arch-pill">ASP.NET Core</span>
                            <span class="project-arch-pill">SQL Server</span>
                            <span class="project-arch-pill">API REST externa</span>
                            <span class="project-arch-pill">Sistema con CRUD</span>
                            <span class="project-arch-pill">Autenticación y roles</span>
                        </div>
                    </div>

                    <div class="project-featured-tags">
                        @foreach (var tag in new List<string> { ".NET", "Blazor", "API REST", "SQL Server", "CRUD" })
                        {
                            <span class="tag">@tag</span>
                        }
                    </div>
                    <div class="project-featured-buttons">
                        <a href="https://youtu.be/Ly_RvPX1kv4" class="project-button demo-button" target="_blank"
                           rel="noopener noreferrer">
                            <svg viewBox="0 0 24 24">
                                <polygon points="5 3 19 12 5 21 5 3" fill="currentColor" stroke="none" />
                            </svg>
                            @Lang.T("verDemo")
                        </a>
                        <a href="https://github.com/NaiquenIturralde/CryptoView" class="project-button code-button"
                           target="_blank" rel="noopener noreferrer">
                            <svg viewBox="0 0 24 24">
                                <path
                                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                            </svg>
                            @Lang.T("verCodigo")
                        </a>
                    </div>
                </div>
            </div>

