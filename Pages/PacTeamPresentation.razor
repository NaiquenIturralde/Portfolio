@page "/pacteampresentation"
@using PortfolioNaiquen.Shared.Components

<PageTitle>Presentación Pac Team - Naiquen Iturralde</PageTitle>

<div class="presentation-page">
    <a href="games" class="back-button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Volver
    </a>

    <div class="presentation-container">
        <header class="presentation-header">
            <h1 class="presentation-title">
                <span class="gradient-text">Presentación de Pac Team</span>
            </h1>
            <div class="download-action">
                <a href="assets/pdfs/PacTeam.pdf" class="pdf-download-btn" aria-label="Descargar PDF"
                   download="PacTeam.pdf">
                    <span class="pdf-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                            <polyline points="7 10 12 15 17 10" />
                            <line x1="12" y1="15" x2="12" y2="3" />
                        </svg>
                    </span>
                    <span class="pdf-label">Descargar PDF</span>
                </a>
            </div>
        </header>

        <div class="presentation-content">
            @for (int i = 1; i <= 7; i++)
            {
                <div class="presentation-slide fade-in">
                    <img src="presentacionPacTeam/@(i).png" alt="Pac Team - Página @i" loading="lazy" />
                </div>
            }
        </div>
    </div>
</div>

@code {

}
