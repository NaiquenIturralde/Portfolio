@page "/certificados"
@using PortfolioNaiquen.Shared.Components
@inject PortfolioNaiquen.Services.LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("navCertificados") - Naiquen Iturralde</PageTitle>

<div class="portfolio-page">
    <section class="page-hero fade-in">
        <div class="hero-content">
            <p class="page-eyebrow">@Lang.T("navCertificados")</p>
            <h1 class="page-title">
                <span class="gradient-text">@Lang.T("certificadosPageTitle")</span>
            </h1>
            <p class="page-subtitle">@Lang.T("certificadosPageSubtitle")</p>
            <p class="page-intro">@Lang.T("certificadosPageIntro")</p>
        </div>
    </section>

    <section class="projects-section fade-in">
        <div class="cert-grid">

            <article class="cert-card glass">
                <div class="cert-card__head">
                    <span class="cert-card__badge" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5z" fill="none"
                                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M14 3v5h5" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                    <p class="cert-card__meta">@Lang.T("certCard1Meta")</p>
                </div>
                <h2 class="cert-card__title">@Lang.T("certCard1Title")</h2>
                <p class="cert-card__desc">@Lang.T("certCard1Desc")</p>
                <div class="cert-card__footer">
                    <a href="certificados/CertificadoDise%C3%B1oGrafico.jpg" target="_blank" rel="noopener noreferrer"
                       class="cert-card__button">
                        @Lang.T("certVerCertificado")
                        <span class="cert-card__arrow" aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="cert-card glass">
                <div class="cert-card__head">
                    <span class="cert-card__badge" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5z" fill="none"
                                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M14 3v5h5" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                    <p class="cert-card__meta">@Lang.T("certCard2Meta")</p>
                </div>
                <h2 class="cert-card__title">@Lang.T("certCard2Title")</h2>
                <p class="cert-card__desc">@Lang.T("certCard2Desc")</p>
                <div class="cert-card__footer">
                    <a href="certificados/CertificadoDise%C3%B1oUX-UI-Figma2026.jpg" target="_blank"
                       rel="noopener noreferrer" class="cert-card__button">
                        @Lang.T("certVerCertificado")
                        <span class="cert-card__arrow" aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="cert-card glass">
                <div class="cert-card__head">
                    <span class="cert-card__badge" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5z" fill="none"
                                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M14 3v5h5" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                    <p class="cert-card__meta">@Lang.T("certCard3Meta")</p>
                </div>
                <h2 class="cert-card__title">@Lang.T("certCard3Title")</h2>
                <p class="cert-card__desc">@Lang.T("certCard3Desc")</p>
                <div class="cert-card__footer">
                    <a href="certificados/CertificadoUdemyASP.NETCore.jpg" target="_blank" rel="noopener noreferrer"
                       class="cert-card__button">
                        @Lang.T("certVerCertificado")
                        <span class="cert-card__arrow" aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="cert-card glass">
                <div class="cert-card__head">
                    <span class="cert-card__badge" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5z" fill="none"
                                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M14 3v5h5" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                    <p class="cert-card__meta">@Lang.T("certCard4Meta")</p>
                </div>
                <h2 class="cert-card__title">@Lang.T("certCard4Title")</h2>
                <p class="cert-card__desc">@Lang.T("certCard4Desc")</p>
                <div class="cert-card__footer">
                    <a href="certificados/ExcelProfesional.png" target="_blank" rel="noopener noreferrer"
                       class="cert-card__button">
                        @Lang.T("certVerCertificado")
                        <span class="cert-card__arrow" aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

            <article class="cert-card glass">
                <div class="cert-card__head">
                    <span class="cert-card__badge" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5z" fill="none"
                                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M14 3v5h5" fill="none" stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                    <p class="cert-card__meta">@Lang.T("certCard5Meta")</p>
                </div>
                <h2 class="cert-card__title">@Lang.T("certCard5Title")</h2>
                <p class="cert-card__desc">@Lang.T("certCard5Desc")</p>
                <div class="cert-card__footer">
                    <a href="certificados/ReporteEdutinAcademy.pdf" target="_blank" rel="noopener noreferrer"
                       class="cert-card__button">
                        @Lang.T("certVerCertificado")
                        <span class="cert-card__arrow" aria-hidden="true">→</span>
                    </a>
                </div>
            </article>

        </div>
    </section>

    <section class="page-cta fade-in">
        <div class="cta-content">
            <h2 class="cta-title">@Lang.T("databasesCtaTitle")</h2>
            <p class="cta-text">@Lang.T("certificadosCtaText")</p>
            <MagicButton Label="@Lang.T("databasesCtaButton")" To="/" AdditionalClass="large" />
        </div>
    </section>

    <section class="page-navigation fade-in">
        <CrossNavigationFooter CurrentPage="certificados" />
    </section>
</div>

@code {
    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }
}
