@inject IJSRuntime JS
@inject PortfolioNaiquen.Services.LanguageService Lang

@if (IsOpen)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-container" @onclick:stopPropagation="true">
            <button class="modal-close" @onclick="Close" aria-label="@Lang.T("close")">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>

            <div class="modal-content">
                <h2 class="modal-title">@Lang.T("contactTitle")</h2>
                
                <div class="contact-info">
                    <a href="tel:+5492954400270" class="contact-item" aria-label="@Lang.T("contactPhoneLabel")">
                        <div class="contact-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path
                                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
                                </path>
                            </svg>
                        </div>
                        <div class="contact-text">
                            <span>+54 9 2954 400270</span>
                            <span class="contact-label">(Argentina)</span>
                        </div>
                    </a>

                    <a href="https://www.google.com/maps?q=Santa+Rosa+La+Pampa" target="_blank" rel="noopener noreferrer"
                           class="contact-item" aria-label="@Lang.T("contactLocationLabel")">
                        <div class="contact-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                        </div>
                        <div class="contact-text">
                            <span>CP: 6300 – Santa Rosa, La Pampa</span>
                        </div>
                    </a>

                    <a href="mailto:iturraldenaiquen@gmail.com" class="contact-item"
                           aria-label="@Lang.T("contactEmailLabel")" @onclick="CopyEmail">
                        <div class="contact-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z">
                                </path>
                                <polyline points="22,6 12,13 2,6"></polyline>
                            </svg>
                        </div>
                        <div class="contact-text">
                            <span>iturraldenaiquen@gmail.com</span>
                        </div>
                    </a>

                    <a href="https://www.instagram.com/Naiiiquiii" target="_blank" rel="noopener noreferrer"
                           class="contact-item" aria-label="@Lang.T("contactInstagramLabel")">
                        <div class="contact-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                            </svg>
                        </div>
                        <div class="contact-text">
                            <span>&#64;Naiiiquiii</span>
                        </div>
                    </a>

                </div>
            </div>
        </div>
    </div>
}

@if (showCopiedToast)
{
    <div class="copied-toast" role="status" aria-live="polite">@Lang.T("copySuccess")</div>
}

@code {
    public bool IsOpen { get; private set; } = false;
    private bool showCopiedToast = false;

    public void Open()
    {
        IsOpen = true;
        StateHasChanged();
    }

    public void Close()
    {
        IsOpen = false;
        StateHasChanged();
    }

    private async Task CopyEmail()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", "iturraldenaiquen@gmail.com");
            showCopiedToast = true;
            StateHasChanged();
            await Task.Delay(2500);
            showCopiedToast = false;
            StateHasChanged();
        }
        catch
        {
            // clipboard API no disponible (requiere HTTPS)
        }
    }
}
