            @if (ShowTechnicaturaProject)
            {
                <div class="software-card glass">
                    <div class="software-card__media">
                        <img src="img/tecnicatura-placeholder.png" alt="Proyectos Tecnicatura" loading="lazy"
                             onerror="this.style.display='none';this.parentElement.setAttribute('data-label','Tecnicatura')" />
                    </div>
                    <div class="software-card__content">
                        <p class="project-meta-label">Trabajos prácticos e integradores</p>
                        <h2 class="project-featured-title">Proyectos Tecnicatura</h2>
                        <p class="project-problem-text">Colección de proyectos del cursado: aplicaciones web, sistemas de
                            gestión, bases de datos relacionales y desarrollo mobile con foco en buenas prácticas.</p>
                            <div class="project-featured-tags">
                                @foreach (var tag in new List<string> { "C#", "Java", "SQL", "Android", "Web" })
                                {
                                    <span class="tag">@tag</span>
                                }
                            </div>
                            <div class="project-featured-buttons">
                                <a href="https://github.com/NaiquenIturralde" class="project-button code-button" target="_blank"
                                   rel="noopener noreferrer">
                                    <svg viewBox="0 0 24 24">
                                        <path
                                        d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                                    </svg>
                                    @Lang.T("verCodigo")
                                </a>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </section>

        <section class="page-navigation fade-in">
            <CrossNavigationFooter CurrentPage="software" />
        </section>
    </div>

@code {
    /// <summary>
    /// Bandera para mostrar/ocultar temporalmente la card "Proyectos Tecnicatura".
    /// Cambiar a <c>true</c> para reactivar.
    /// </summary>
    private bool ShowTechnicaturaProject = false;

    protected override void OnInitialized()
    {
        Lang.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Lang.OnChange -= StateHasChanged;
    }
}
