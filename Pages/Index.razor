@using PortfolioNaiquen.Shared

<div class="hero-section text-center mt-20">
    <span class="text-lg font-semibold text-purple-400">
        Bienvenido a mi portfolio
    </span>

    <h1 class="text-6xl font-extrabold text-purple-400 mt-4">
        Yo soy Naiquen Anael Iturralde
    </h1>

    <p class="text-gray-300 text-xl mt-6 max-w-2xl mx-auto">
        Desarrolladora Full Stack y Game Developer.
        Estudiante avanzada de la Tecnicatura Superior en Desarrollo de Software (ITES)
        y en formación en Diseño UX.
        Me enfoco en crear experiencias digitales accesibles e inclusivas,
        pensando siempre en un mundo donde todas las personas puedan interactuar sin barreras.
    </p>

    <div class="mt-10">
        <img src="@ProfileImage.Url" alt="@ProfileImage.Alt" class="rounded-xl shadow-lg mx-auto"
             style="max-width: 260px; border: 2px solid rgba(255,255,255,0.15);" />
    </div>

    <div class="mt-12 flex justify-center">
        <a href="/about"
           class="px-6 py-3 rounded-xl bg-purple-600 hover:bg-purple-700 transition text-white font-semibold shadow-lg">
            Acerca de mí
        </a>
    </div>

</div>
